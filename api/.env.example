# Copy to .env (or set in your hosting provider). All optional unless noted.

# Server
PORT=4040

# Admin login (CHANGE BEFORE DEPLOY)
ADMIN_USER=admin
ADMIN_PASS=changeme

# Where to send notification emails
NOTIFY_EMAIL=engage@legalchampions.my
MAIL_FROM=Legal Champions <noreply@legalchampions.my>

# SMTP (any provider — Postmark, SendGrid, Resend, Gmail with app password, etc.)
# Leave blank to disable email entirely (submissions still captured to DB).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Where to store the SQLite file (defaults to ../data/leads.db)
# DB_PATH=/var/data/leads.db
